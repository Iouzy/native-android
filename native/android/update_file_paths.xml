<?xml version="1.0" encoding="utf-8"?>
<!-- FileProvider paths for the in-app updater (AppUpdaterPlugin) AND the native
     share sheet (FocusActivityPlugin.shareImage). The downloaded update.apk lives
     in the app-specific external files dir; shared images live in cache/share. We
     expose just those directories to other apps via a content:// URI. A separate
     authority (.updateprovider) keeps this independent of Capacitor's own
     .fileprovider so neither clobbers the other. -->
<paths>
    <external-files-path name="updates" path="." />
    <files-path name="internal_updates" path="." />
    <cache-path name="shared" path="share/" />
</paths>
